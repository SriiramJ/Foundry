{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "installCommand": "npm install",
  "framework": "nextjs",
  "functions": {
    "app/api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/api/weekly-digest",
      "schedule": "0 9 * * 1"
    }
  ],
  "env": {
    "NEXTAUTH_URL": "https://your-app.vercel.app"
  }
}